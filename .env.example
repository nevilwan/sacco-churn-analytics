# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://sacco_user:sacco_pass@localhost:5432/sacco_experiments
DATABASE_TEST_URL=postgresql://sacco_user:sacco_pass@localhost:5432/sacco_experiments_test

# ─── Security ────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKENIZATION_SECRET_KEY=REPLACE_WITH_GENERATED_FERNET_KEY
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ─── Application ─────────────────────────────────────────────────
APP_ENV=development
APP_NAME=SACCO Retention Analysis System
LOG_LEVEL=INFO
# Minimum cohort size shown in dashboard (privacy protection)
MIN_COHORT_DISPLAY_SIZE=30

# ─── Dashboard ───────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# ─── API ─────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
